# Copy this file to .env and fill in real values before running docker compose up --build

# Google OAuth 2.0 (create credentials at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=changeme.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=changeme
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

# Session
JWT_SECRET=dev-secret-change-me

# Datastores (defaults match docker-compose service names, no need to change for docker compose up)
MONGO_URI=mongodb://mongo:27017/cinema
REDIS_ADDR=redis:6379
KAFKA_BROKERS=kafka:9092

# Where the frontend is served, used for post-login redirect
FRONTEND_ORIGIN=http://localhost:5173

# Seat lock duration in seconds (5 minutes per spec; lower this for fast manual testing)
LOCK_TTL_SECONDS=300

PORT=8080
